# =============================================================================
# Claimflow — Environment Variables
# Copy this file to `.env` and fill in your credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Alibaba Cloud DashScope (Qwen LLM API)
# Obtain your API key at: https://dashscope.console.aliyun.com/
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI-compatible DashScope endpoint (international region)
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Qwen model used for triage and risk assessment
LLM_MODEL_NAME=qwen-max

# Fallback models when the primary LLM is unavailable (comma-separated or JSON array)
LLM_FALLBACK_MODELS=qwen-plus,qwen-turbo

# Qwen-VL model for multimodal claim image analysis
VISION_MODEL_NAME=qwen-vl-max

# Fallback vision models when the primary Qwen-VL model is unavailable
VISION_FALLBACK_MODELS=qwen-vl-plus
# VISION_TIMEOUT_SECONDS=60
# LLM_TIMEOUT_SECONDS=60

# Score thresholds for automated routing (0.0 – 1.0)
# RISK_THRESHOLD=0.7
# REJECT_THRESHOLD=0.9

# Use deterministic MockLLM scenarios instead of live DashScope calls (hackathon demos)
# USE_MOCK_LLM=false

# -----------------------------------------------------------------------------
# Alibaba Cloud IAM credentials (used for OSS and other cloud services)
# Create access keys at: https://ram.console.aliyun.com/manage/ak
# -----------------------------------------------------------------------------
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret_here

# -----------------------------------------------------------------------------
# Alibaba Cloud OSS (Object Storage Service) — document storage for claims
# -----------------------------------------------------------------------------
OSS_BUCKET_NAME=your-oss-bucket-name
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# -----------------------------------------------------------------------------
# File storage strategy (Strategy pattern)
# Use "local" during development while OSS account is pending verification.
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads
# LOCAL_UPLOAD_BASE_URL=http://localhost:8000

# OSS region and pre-signed URL settings (when STORAGE_BACKEND=oss)
# OSS_REGION=cn-hangzhou
# OSS_PRESIGN_EXPIRY_SECONDS=3600
# OSS_OBJECT_PREFIX=claims/

# -----------------------------------------------------------------------------
# PostgreSQL (default — claim persistence + LangGraph checkpoints)
# docker compose starts Postgres as claimflow:claimflow@localhost:5432/claimflow
# For quick testing without Postgres, set DATABASE_URL= (empty) to use in-memory.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://claimflow:claimflow@localhost:5432/claimflow
CHECKPOINT_DATABASE_URL=postgresql://claimflow:claimflow@localhost:5432/claimflow

# -----------------------------------------------------------------------------
# Application settings
# -----------------------------------------------------------------------------
# Shared secret for X-API-Key auth on mutating endpoints
# (POST /claims/submit, POST /uploads, POST /review/*/decision).
# GET /health stays public. For production, set a strong random API_KEY.
API_KEY=cf_hk_a8f3b2c19e4d5f60718293a4b5c6d7e8

# API version prefix for all routes (e.g. /api/v1/claims)
API_V1_STR=/api/v1

# Display name used in OpenAPI docs and health checks
PROJECT_NAME=Claimflow Autopilot

# Optional overrides (sensible defaults are applied when omitted)
# LOG_LEVEL=INFO
# ENVIRONMENT=development
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
